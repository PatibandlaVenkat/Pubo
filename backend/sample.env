PUBO_PRIMARY.ENV="local"

PUBO_SERVER.PORT="8080"
PUBO_SERVER.READ_TIMEOUT="30"
PUBO_SERVER.WRITE_TIMEOUT="30"
PUBO_SERVER.IDLE_TIMEOUT="60"
PUBO_SERVER.CORS_ALLOWED_ORIGINS="http://localhost:3000"

PUBO_DATABASE.HOST="localhost"
PUBO_DATABASE.PORT="5432"
PUBO_DATABASE.USER="postgres"
PUBO_DATABASE.PASSWORD=""
PUBO_DATABASE.NAME="tasker"
PUBO_DATABASE.SSL_MODE="disable"
PUBO_DATABASE.MAX_OPEN_CONNS="25"
PUBO_DATABASE.MAX_IDLE_CONNS="25"
PUBO_DATABASE.CONN_MAX_LIFETIME="300"
PUBO_DATABASE.CONN_MAX_IDLE_TIME="300"

PUBO_AUTH.SECRET_KEY="secret"

PUBO_INTEGRATION.RESEND_API_KEY="resend_key"

PUBO_REDIS.ADDRESS="redis://localhost:6379"
PUBO_REDIS.PASSWORD=


# ============================================================================
# OBSERVABILITY CONFIGURATION
# ============================================================================

# Service Identity
PUBO_OBSERVABILITY.SERVICE_NAME="tasker"
PUBO_OBSERVABILITY.ENVIRONMENT="development"

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

# Basic Logging Settings
PUBO_OBSERVABILITY.LOGGING.LEVEL="debug"
PUBO_OBSERVABILITY.LOGGING.FORMAT="console"
PUBO_OBSERVABILITY.LOGGING.SLOW_QUERY_THRESHOLD="100ms"

# ============================================================================
# NEW RELIC CONFIGURATION
# ============================================================================

# New Relic APM
PUBO_OBSERVABILITY.NEW_RELIC.LICENSE_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
PUBO_OBSERVABILITY.NEW_RELIC.APP_LOG_FORWARDING_ENABLED="true"
PUBO_OBSERVABILITY.NEW_RELIC.DISTRIBUTED_TRACING_ENABLED="true"
PUBO_OBSERVABILITY.NEW_RELIC.DEBUG_LOGGING="false"

# ============================================================================
# HEALTH CHECKS CONFIGURATION
# ============================================================================

# Health Check Settings
PUBO_OBSERVABILITY.HEALTH_CHECKS.ENABLED="true"
PUBO_OBSERVABILITY.HEALTH_CHECKS.INTERVAL="30s"
PUBO_OBSERVABILITY.HEALTH_CHECKS.TIMEOUT="5s"
PUBO_OBSERVABILITY.HEALTH_CHECKS.CHECKS="database,redis"
